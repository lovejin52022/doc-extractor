# Doc Extractor 环境配置示例
# 复制此文件为 .env 并根据实际情况修改

# ========== API 配置 ==========
# API 密钥（可选）
# OPENAI_API_KEY=sk-xxx
# ANTHROPIC_API_KEY=sk-ant-xxx

# ========== LLM 配置 ==========
# LLM 提供商: ollama, openai, anthropic
LLM_PROVIDER=ollama
# LLM 模型
LLM_MODEL=llama2
# Ollama 地址
LLM_BASE_URL=http://localhost:11434

# ========== Embedding 配置 ==========
# Embedding 提供商: ollama, openai
EMBEDDING_PROVIDER=ollama
# Embedding 模型
EMBEDDING_MODEL=nomic-embed-text
# Embedding 维度
EMBEDDING_DIMENSION=768

# ========== 向量数据库配置 ==========
# 向量数据库类型: lancedb
VECTOR_DB_PROVIDER=lancedb
# 向量数据库存储路径
VECTOR_DB_PATH=./storage/vectors

# ========== 文档解析配置 ==========
# 默认分块大小（字符数）
DEFAULT_CHUNK_SIZE=500
# 默认分块重叠
DEFAULT_CHUNK_OVERLAP=50
# 默认分块策略: fixed, paragraph, recursive
DEFAULT_CHUNK_STRATEGY=fixed

# ========== RAG 配置 ==========
# 默认返回结果数量
DEFAULT_TOP_K=5
# 相似度阈值
DEFAULT_SCORE_THRESHOLD=0.5

# ========== 服务器配置 ==========
# API 端口
API_PORT=8000
# 前端端口
FRONTEND_PORT=3000
